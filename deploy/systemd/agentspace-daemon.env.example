# AgentSpace remote daemon environment template
# Copy to /etc/agentspace/daemon.env and fill real values.

AGENT_SPACE_SERVER_URL=https://your-agentspace-domain
AGENT_SPACE_DAEMON_TOKEN=replace_with_daemon_token
AGENT_SPACE_DAEMON_ID=daemon-prod-01
AGENT_SPACE_DEVICE_NAME=prod-daemon-host-01
AGENT_SPACE_RUNTIME_NAME=Remote Agent
AGENT_SPACE_DAEMON_STATE_DIR=/var/lib/agent-space-daemon
AGENT_SPACE_TASK_TIMEOUT_MS=43200000
# Optional provider-specific overrides
CLAUDE_MODEL=claude-haiku-4-5-20251001
ANTIGRAVITY_MODEL=Gemini 3.5 Flash
GEMINI_MODEL=gemini-2.0-flash-lite
OPENCODE_MODEL=openrouter/openai/gpt-4.1
# OpenClaw uses AgentRouter only. OpenClaw 2026.3.3 has no explicit
# `openclaw agent --model`, so daemon passes model as OPENCLAW_MODEL.
OPENCLAW_PROFILE=default
OPENCLAW_MODEL=openrouter/openai/gpt-4.1
# Optional thinking mode passed as `openclaw agent --thinking`.
OPENCLAW_THINKING=medium
NANOBOT_MODEL=openai/gpt-5-mini
NANOBOT_CONFIG_PATH=/etc/agentspace/nanobot.json
