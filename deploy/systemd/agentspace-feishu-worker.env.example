# AgentSpace Feishu WebSocket worker environment.
# Copy to /etc/agentspace/feishu-worker.env for deploy/systemd/agentspace-feishu-worker.service.

AGENT_SPACE_WORKSPACE_ID=default

# PostgreSQL primary database. Use the same database as the AgentSpace web app.
AGENT_SPACE_PG_URL=postgres://agent_space:agent_space@127.0.0.1:5432/agent_space
DATABASE_URL=postgres://agent_space:agent_space@127.0.0.1:5432/agent_space

# Required to decrypt Feishu app_secret / verification_token / encrypt_key saved by the web UI.
# Must match the key used by the web app when the Feishu integration was created.
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AGENT_SPACE_FEISHU_CREDENTIAL_ENCRYPTION_KEY=replace_with_base64_encoded_32_byte_key

# Optional: restrict this worker to one integration id.
AGENT_SPACE_FEISHU_INTEGRATION_ID=

# Optional: identify this worker in outbox locks and logs.
AGENT_SPACE_FEISHU_WORKER_ID=feishu-worker-prod-01

# Optional: use accounts.larksuite.com for Lark tenants instead of the default Feishu domain.
AGENT_SPACE_FEISHU_WS_DOMAIN=

# Optional: override Feishu API base URL for private/test environments.
AGENT_SPACE_FEISHU_API_BASE_URL=
