# Required for --live.
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_VERIFICATION_TOKEN=xxx
# Optional but recommended when Feishu event encryption is enabled.
FEISHU_ENCRYPT_KEY=xxx

# Optional TODO120 multi-agent smoke: use a second disposable Feishu app/bot
# for another AgentSpace agent, such as HermesAgent Bot.
FEISHU_SECOND_AGENT_APP_ID=cli_second_xxx
FEISHU_SECOND_AGENT_APP_SECRET=xxx

# Optional. Defaults to https://open.feishu.cn.
# FEISHU_API_BASE_URL=https://open.feishu.cn

# AgentSpace callback smoke: copy the integration detail callback URL from Settings.
FEISHU_SMOKE_CALLBACK_URL=https://agentspace.example.com/api/integrations/feishu/events?workspaceId=workspace_xxx&integrationId=integration_xxx

# IM smoke: bot must be in this chat and have im:message:send_as_bot.
FEISHU_SMOKE_CHAT_ID=oc_xxx

# Docs smoke: app must be authorized to read/write this disposable docx document.
FEISHU_SMOKE_DOC_TOKEN=doccn_xxx
# Use a disposable parent block; the append check mutates it.
FEISHU_SMOKE_DOC_PARENT_BLOCK_ID=blk_xxx
FEISHU_SMOKE_DOC_APPEND_BLOCKS_JSON=[{"block_type":2,"text":{"elements":[{"text_run":{"content":"AgentSpace smoke"}}]}}]

# Sheets smoke: app must be authorized to read/write this spreadsheet.
# Use a disposable cell range; the write check mutates it.
FEISHU_SMOKE_SHEET_TOKEN=shtcn_xxx
# Optional read range. Defaults to Sheet1!A1:B2 when unset.
FEISHU_SMOKE_SHEET_RANGE=Sheet1!A1:B2
FEISHU_SMOKE_SHEET_WRITE_RANGE=Sheet1!A1:B1
FEISHU_SMOKE_SHEET_WRITE_VALUES_JSON=[["AgentSpace smoke"]]

# Base/Bitable smoke: app must be authorized to read/update this table.
# Use a disposable record; the update check mutates it.
FEISHU_SMOKE_BASE_APP_TOKEN=app_xxx
FEISHU_SMOKE_BASE_TABLE_ID=tbl_xxx
FEISHU_SMOKE_BASE_RECORD_ID=rec_xxx
FEISHU_SMOKE_BASE_UPDATE_FIELDS_JSON={"Smoke":"AgentSpace"}
